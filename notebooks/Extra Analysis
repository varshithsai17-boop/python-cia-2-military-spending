   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Ensure numeric columns are correct types\n",
    "sipri['Spending (US$ bn)'] = pd.to_numeric(sipri['Spending (US$ bn)'], errors='coerce')\n",
    "sipri['% of GDP'] = pd.to_numeric(sipri['% of GDP'], errors='coerce')\n",
    "sipri['% of global spending'] = pd.to_numeric(sipri['% of global spending'], errors='coerce')\n",
    "\n",
    "print(\" Data types verified and cleaned.\")\n",
    "print(sipri.dtypes)"
   ]
