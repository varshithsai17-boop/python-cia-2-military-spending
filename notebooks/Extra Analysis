    "sipri_indexed.loc[['United States', 'China', 'India', 'Russia']]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.4  Boolean Filtering"
   ]
  },
  {
   "cell_type": "code",
