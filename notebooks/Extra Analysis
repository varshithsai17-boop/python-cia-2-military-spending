    "print(f\"Countries spending over $50 bn: {len(high_spenders)}\")\n",
    "high_spenders[['Country', 'Spending (US$ bn)', '% of GDP']]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
