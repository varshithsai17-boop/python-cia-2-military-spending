    "print(f\"   IISS 2025:       {iiss.shape[0]} rows × {iiss.shape[1]} columns\")\n",
    "print(f\"   GDP % (SIPRI):   {gdp_sipri.shape[0]} rows × {gdp_sipri.shape[1]} columns\")\n",
    "print(f\"   GDP % (IISS):    {gdp_iiss.shape[0]} rows × {gdp_iiss.shape[1]} columns\")"
